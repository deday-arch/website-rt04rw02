# ============================================================
#  ENVIRONMENT VARIABLES - Backend RT 04 / RW 02
#  Salin file ini ke .env dan isi nilainya
#  JANGAN commit file .env ke git!
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ── PostgreSQL Azure ─────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DB_HOST=rt04rw02-db.postgres.database.azure.com
DB_PORT=5432
DB_NAME=rt04rw02
DB_USER=rtadmin
DB_PASSWORD=ganti_dengan_password_kuat
DB_SSL=true                   # true untuk Azure (wajib)
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000         # ms — koneksi idle ditutup setelah 30 detik
DB_CONNECTION_TIMEOUT=5000    # ms — timeout saat koneksi gagal

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=ganti_dengan_secret_panjang_minimal_32_karakter
JWT_EXPIRES_IN=8h             # sesi admin kedaluwarsa setelah 8 jam

# ── CORS ─────────────────────────────────────────────────────
# URL frontend yang diizinkan (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN=https://deday-arch.github.io,http://localhost:5500

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 menit
RATE_LIMIT_MAX=100            # maks 100 request per window per IP
